generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ServiceType {
  id     Int    @id @default(autoincrement())
  name   String
  slug   String @unique
  icon   String?
  status Int    @default(1)

  businesses BusinessServiceType[]
}

model BusinessServiceType {
  businessId    String
  serviceTypeId Int
  business      Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  serviceType   ServiceType @relation(fields: [serviceTypeId], references: [id], onDelete: Cascade)

  @@id([businessId, serviceTypeId])
}

model Business {
  id                   String   @id @default(uuid())
  name                 String?
  ownerName            String?
  sameAsOwnerNumber    Boolean  @default(false)
  contactNumber        String?
  email                String?
  address              String?
  cateringTypes        String[] @default([])
  yearsExperience      Int?
  registrationNumber   String?
  gstNumber            String?
  logoUrl              String?

  subscriptionStatus String? @default("trial")
  subscriptionPlan     String? @default("FREE")
  subscriptionStart    DateTime?
  subscriptionEnd      DateTime?
  isTrialUsed          Boolean @default(false)

  createdByUserId String?
  createdBy       User?   @relation("BusinessCreatedBy", fields: [createdByUserId], references: [id])

  isProfileCompleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  serviceLinks BusinessServiceType[]
}

model User {
  id                 String    @id @default(uuid())
  businessId         String?
  name               String
  email              String    @unique
  passwordHash       String
  phoneNumber        String?
  role               String    @default("owner")
  isVerified         Boolean   @default(false)
  notificationStatus Int       @default(1)
  userVerifiedAt     DateTime?

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business          Business? @relation(fields: [businessId], references: [id])
  devices           UserDevice[]
  businessesCreated Business[] @relation("BusinessCreatedBy")
}

model UserDevice {
  id         String   @id @default(uuid())
  userId     String
  deviceType Int
  fcmToken   String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model OtpCode {
  id        String   @id @default(uuid())
  email     String
  otp       String
  type      String
  expiresAt DateTime
  attempts  Int      @default(0)
  isUsed    Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
