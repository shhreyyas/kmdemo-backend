generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ServiceType {
  id     Int    @id @default(autoincrement())
  name   Json
  slug   String @unique
  icon   String?
  status Int    @default(1)

  businesses BusinessServiceType[]
}

model BusinessServiceType {
  businessId    String
  serviceTypeId Int
  business      Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  serviceType   ServiceType @relation(fields: [serviceTypeId], references: [id], onDelete: Cascade)

  @@id([businessId, serviceTypeId])
}

model Business {
  id                   String   @id @default(uuid())
  name                 String?
  ownerName            String?
  sameAsOwnerNumber    Boolean  @default(false)
  contactNumber        String?
  email                String?
  address              String?
  cateringTypes        String[] @default([])
  yearsExperience      Int?
  registrationNumber   String?
  gstNumber            String?
  logoUrl              String?

  subscriptionStatus String? @default("trial")
  subscriptionPlan     String? @default("FREE")
  subscriptionStart    DateTime?
  subscriptionEnd      DateTime?
  isTrialUsed          Boolean @default(false)
  razorpayCustomerId   String?

  createdByUserId String?
  createdBy       User?   @relation("BusinessCreatedBy", fields: [createdByUserId], references: [id])

  isProfileCompleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  defaultServiceChargePct Decimal @default(10) @db.Decimal(5, 2)
  defaultTaxPct           Decimal @default(5) @db.Decimal(5, 2)

  users        User[]
  serviceLinks BusinessServiceType[]
  menuItems    MenuItem[]
  dishes       Dish[]
  bookings     Booking[]
  quotations   Quotation[]
  supplyItems SupplyItem[]
  supplySavedLists SupplySavedList[]
  vendors     Vendor[]
  staff       Staff[]
  extraServices ExtraService[]
  billingSubscriptions BillingSubscription[]
  billingPaymentEvents BillingPaymentEvent[]
}

/// Mirrors Razorpay subscription; one row per active/historical app subscription.
model BillingSubscription {
  id                     String    @id @default(uuid())
  businessId             String
  business               Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  razorpaySubscriptionId String    @unique
  razorpayPlanId         String
  planCode               String?
  status                 String
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean   @default(false)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  paymentEvents BillingPaymentEvent[]

  @@index([businessId])
}

model BillingPaymentEvent {
  id                      String               @id @default(uuid())
  businessId              String
  business                Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  billingSubscriptionId   String?
  billingSubscription     BillingSubscription? @relation(fields: [billingSubscriptionId], references: [id], onDelete: SetNull)
  razorpayPaymentId       String?              @unique
  razorpayInvoiceId       String?
  amountPaise             BigInt               @default(0)
  status                  String
  rawWebhookEventId       String?
  createdAt               DateTime             @default(now())

  @@index([businessId])
  @@index([billingSubscriptionId])
}

/// Razorpay webhook dedupe + debugging (idempotent processing).
model WebhookInbox {
  id          String    @id @default(uuid())
  eventId     String    @unique
  payload     Json
  processedAt DateTime?
  error       String?
  createdAt   DateTime  @default(now())
}

model User {
  id                 String    @id @default(uuid())
  businessId         String?
  name               String
  email              String    @unique
  passwordHash       String
  phoneNumber        String?
  profileImageUrl    String?
  pdfPrefix          String?   @default("KAT-2024")
  role               String    @default("owner")
  isVerified         Boolean   @default(false)
  notificationStatus Int       @default(1)
  userVerifiedAt     DateTime?

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business          Business? @relation(fields: [businessId], references: [id])
  devices           UserDevice[]
  businessesCreated Business[] @relation("BusinessCreatedBy")
  menuItemsCreated  MenuItem[]
  supplyItemsCreated SupplyItem[]
  supplySavedListsCreated SupplySavedList[] @relation("SupplySavedListCreator")
  contactMessages   ContactMessage[]
}

model ContactMessage {
  id           String   @id @default(uuid())
  email        String
  customerName String
  phone        String?
  description  String
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

model UserDevice {
  id         String   @id @default(uuid())
  userId     String
  deviceType Int
  fcmToken   String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model MenuItem {
  /// Server-generated UUID; not accepted from clients on create.
  id              String   @id @default(uuid())
  name            Json
  description     String?  @db.Text
  howToMake       String?  @db.Text
  pricePerPerson  Decimal  @db.Decimal(12, 2)
  categorySlug    String
  foodType        String
  businessId      String?
  createdByUserId String?
  /// false only when both businessId and createdByUserId are set; otherwise true (catalog / import).
  isGlobal        Boolean  @default(false)
  parentMenuId    String?
  ingredients     Json     @default("[]")
  imageUrl        String?

  business    Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdBy   User?     @relation(fields: [createdByUserId], references: [id])
  category    MenuCategory @relation(fields: [categorySlug], references: [slug])
  parentMenu  MenuItem? @relation("MenuItemLineage", fields: [parentMenuId], references: [id])
  childCopies MenuItem[] @relation("MenuItemLineage")
  bookingMenuItems    BookingMenuItem[]
  quotationMenuItems  QuotationMenuItem[]
  dishMenuItems       DishMenuItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([createdByUserId])
  @@index([isGlobal])
  @@index([parentMenuId])
  @@index([categorySlug])
}

/// Global menu categories (admin-managed). Names are localized JSON maps.
model MenuCategory {
  id        String   @id @default(uuid())
  name      Json
  slug      String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  menuItems MenuItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model OtpCode {
  id        String   @id @default(uuid())
  email     String
  otp       String
  type      String
  expiresAt DateTime
  attempts  Int      @default(0)
  isUsed    Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum BookingStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  RECEIVED
}

enum PaymentMethod {
  CASH
  UPI
  BANK_TRANSFER
}

enum EventStatus {
  PENDING
  CONFIRMED
  COMPLETED
}

enum SupplyItemType {
  INGREDIENT
  UTENSIL
}

enum QuotationStatus {
  DRAFT
  SALE
  SENT
  ACCEPTED
}

enum StaffRole {
  CHEF
  HELPER
  WAITER
  MANAGER
  CLEANER
  VIP_SERVICE_BOY
  COUNTER_STAFF
  DECORATION_STAFF
}

enum StaffStatus {
  AVAILABLE
  BUSY
  ON_LEAVE
  INACTIVE
}

enum ExtraServicePricingType {
  FIXED
  PER_UNIT
  PER_GUEST
}

model Booking {
  id     String @id @default(uuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  status      BookingStatus @default(DRAFT)
  stepNumber  Int           @default(1)
  bookingCode String?

  customerName  String?
  customerPhone String?
  customerEmail String?
  eventRangeStart DateTime?
  eventRangeEnd   DateTime?

  eventAt       DateTime?
  eventLocation String?
  functionType  String?
  guestCount    Int?
  notes         String? @db.Text

  discountAmount      Decimal @default(0) @db.Decimal(12, 2)
  serviceChargePct    Decimal @default("10") @db.Decimal(5, 2)
  taxPct              Decimal @default("5") @db.Decimal(5, 2)
  subtotal            Decimal @default(0) @db.Decimal(12, 2)
  serviceChargeAmount Decimal @default(0) @db.Decimal(12, 2)
  taxAmount           Decimal @default(0) @db.Decimal(12, 2)
  totalDue            Decimal @default(0) @db.Decimal(12, 2)
  amountPaid          Decimal @default(0) @db.Decimal(12, 2)
  paymentStatus       PaymentStatus @default(PENDING)

  menuItems BookingMenuItem[]
  supplyItems BookingSupplyItem[]
  payments  PaymentTransaction[]
  events    BookingEvent[]
  extraServiceLines BookingExtraServiceLine[]

  /// Set when the caterer marks the booking as completed in the app (dashboard / history).
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, bookingCode])
  @@index([businessId, status])
  @@index([businessId, eventAt])
  @@index([businessId, completedAt])
}

model BookingEvent {
  id           String      @id @default(uuid())
  bookingId    String
  eventAt      DateTime?
  eventLocation String?
  functionType String?
  guestCount   Int?
  notes        String?     @db.Text
  status       EventStatus @default(PENDING)
  dishId       String?
  parentDishId String?
  isTemplate   Boolean?
  eventTotal   Decimal?    @db.Decimal(12, 2)
  eventSnapshot Json?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  supplyItems BookingEventSupplyItem[]
  supplySavedLists SupplySavedList[]
  staffAssignments EventStaff[]
  extraServiceLines BookingExtraServiceLine[]

  @@index([bookingId])
  @@index([bookingId, eventAt])
}

model BookingMenuItem {
  id                    String  @id @default(uuid())
  bookingId             String
  menuItemId            String
  quantity              Int     @default(1)
  pricePerPlateSnapshot Decimal @db.Decimal(12, 2)
  nameSnapshot          String?
  imageUrlSnapshot      String?

  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Restrict)

  @@unique([bookingId, menuItemId])
  @@index([bookingId])
}

model SupplyItem {
  id             String @id @default(uuid())
  businessId     String?
  business       Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdByUserId String?
  createdBy       User?     @relation(fields: [createdByUserId], references: [id])
  /// false only when both businessId and createdByUserId are set; otherwise true (catalog / import).
  isGlobal       Boolean  @default(false)
  type           SupplyItemType
  categorySlug   String
  category       SupplyItemCategory @relation(fields: [categorySlug], references: [slug], onDelete: Restrict)
  name           Json
  unitOptions    String[] @default([])
  defaultUnit    String
  availableCount Int?
  photoUrl       String?
  isActive       Boolean @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  bookingSupplyItems BookingSupplyItem[]
  bookingEventSupplyItems BookingEventSupplyItem[]
  supplySavedListItems SupplySavedListItem[]

  @@index([businessId])
  @@index([createdByUserId])
  @@index([isGlobal])
  @@index([businessId, type, categorySlug, isActive])
  @@index([categorySlug])
}

model BookingSupplyItem {
  id             String @id @default(uuid())
  bookingId      String
  supplyItemId   String
  quantity       Int @default(1)
  unit           String
  categorySlug   String
  category       SupplyItemCategory @relation(fields: [categorySlug], references: [slug], onDelete: Restrict)
  nameSnapshot   Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  booking      Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  supplyItem   SupplyItem   @relation(fields: [supplyItemId], references: [id], onDelete: Restrict)

  @@unique([bookingId, supplyItemId])
  @@index([bookingId, categorySlug])
  @@index([categorySlug])
}

model BookingEventSupplyItem {
  id             String @id @default(uuid())
  bookingEventId String
  supplyItemId   String
  itemType       SupplyItemType
  quantity       Int @default(1)
  unit           String
  categorySlug   String
  category       SupplyItemCategory @relation(fields: [categorySlug], references: [slug], onDelete: Restrict)
  nameSnapshot   Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  bookingEvent BookingEvent @relation(fields: [bookingEventId], references: [id], onDelete: Cascade)
  supplyItem   SupplyItem   @relation(fields: [supplyItemId], references: [id], onDelete: Restrict)

  @@unique([bookingEventId, supplyItemId])
  @@index([bookingEventId, itemType])
  @@index([categorySlug])
}

/// Supply categories are admin-managed and referenced by slug from supply tables.
model SupplyItemCategory {
  id        String   @id @default(uuid())
  name      Json
  slug      String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  supplyItems           SupplyItem[]
  bookingSupplyItems    BookingSupplyItem[]
  bookingEventSupplyItems BookingEventSupplyItem[]

  @@index([isActive, sortOrder])
}

/// Admin-managed Units catalog used globally across modules.
model Unit {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("Units")
}

model Dish {
  id            String   @id @default(uuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name          String
  pricePerPlate Decimal  @default(0) @db.Decimal(12, 2)
  isTemplate    Boolean  @default(true)
  parentDishId  String?
  parentDish    Dish?    @relation("DishLineage", fields: [parentDishId], references: [id])
  childDishes   Dish[]   @relation("DishLineage")
  menuItems     DishMenuItem[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([businessId])
  @@index([parentDishId])
}

model DishMenuItem {
  id          String   @id @default(uuid())
  dishId      String
  menuItemId  String
  quantity    Int      @default(1)
  dish        Dish     @relation(fields: [dishId], references: [id], onDelete: Cascade)
  menuItem    MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())

  @@unique([dishId, menuItemId])
  @@index([dishId])
}

model PaymentTransaction {
  id        String        @id @default(uuid())
  bookingId String
  amount    Decimal       @db.Decimal(12, 2)
  method    PaymentMethod
  createdAt DateTime      @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

model Quotation {
  id     String @id @default(uuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  status QuotationStatus @default(SALE)

  clientName  String
  clientPhone String?
  functionType String?
  eventDate   DateTime?
  guestCount  Int       @default(0)
  discountAmount      Decimal @default(0) @db.Decimal(12, 2)
  serviceChargePct    Decimal @default("10") @db.Decimal(5, 2)
  taxPct              Decimal @default("5") @db.Decimal(5, 2)
  subtotal            Decimal @db.Decimal(12, 2)
  serviceChargeAmount Decimal @db.Decimal(12, 2)
  taxAmount           Decimal @db.Decimal(12, 2)
  total               Decimal @db.Decimal(12, 2)
  /// Agreed per-guest menu bundle (custom or predefined); null when only per-line catalog snapshots apply.
  platePrice Decimal? @db.Decimal(12, 2)

  menuItems QuotationMenuItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
}

model QuotationMenuItem {
  id                    String  @id @default(uuid())
  quotationId           String
  menuItemId            String
  pricePerPlateSnapshot Decimal @db.Decimal(12, 2)
  nameSnapshot          String?

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  menuItem  MenuItem  @relation(fields: [menuItemId], references: [id], onDelete: Restrict)

  @@unique([quotationId, menuItemId])
  @@index([quotationId])
}

/// Caterer-owned persisted ingredient supply lists (standalone MVP; not tied to bookings unless linked).
model SupplySavedList {
  id               String   @id @default(uuid())
  businessId       String
  business         Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdByUserId  String?
  createdBy        User?    @relation("SupplySavedListCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  title            String   @db.VarChar(512)
  bookingEventId   String?
  bookingEvent     BookingEvent? @relation(fields: [bookingEventId], references: [id], onDelete: SetNull)
  categoriesLabel  String?  @db.VarChar(512)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  items            SupplySavedListItem[]

  @@index([businessId, createdAt(sort: Desc)])
  @@index([bookingEventId])
}

model SupplySavedListItem {
  id             String @id @default(uuid())
  listId         String
  list           SupplySavedList @relation(fields: [listId], references: [id], onDelete: Cascade)
  supplyItemId   String
  supplyItem     SupplyItem @relation(fields: [supplyItemId], references: [id], onDelete: Restrict)
  quantity       Int
  unit           String
  categorySlug   String
  nameSnapshot   Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([listId])
  @@index([supplyItemId])
}

model Vendor {
  id         String   @id @default(uuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String
  address    String?
  whatsappNo String?
  categorySlug String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([businessId, isActive])
}

model Staff {
  id          String      @id @default(uuid())
  businessId  String
  business    Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name        String
  phone       String?
  role        StaffRole
  dailyCharge Decimal?    @db.Decimal(12, 2)
  status      StaffStatus @default(AVAILABLE)
  isAvailable Boolean     @default(true)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  assignments EventStaff[]

  @@index([businessId, role, isActive])
}

model EventStaff {
  id               String       @id @default(uuid())
  bookingEventId   String
  staffId          String
  role             StaffRole
  assignedByUserId String?
  allowConflict    Boolean      @default(false)
  createdAt        DateTime     @default(now())
  bookingEvent     BookingEvent @relation(fields: [bookingEventId], references: [id], onDelete: Cascade)
  staff            Staff        @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([bookingEventId, staffId])
  @@index([staffId])
  @@index([bookingEventId])
}

model ExtraService {
  id           String                  @id @default(uuid())
  businessId   String
  business     Business                @relation(fields: [businessId], references: [id], onDelete: Cascade)
  title        String
  description  String?                 @db.Text
  pricingType  ExtraServicePricingType
  price        Decimal                 @db.Decimal(12, 2)
  isOptional   Boolean                 @default(true)
  isActive     Boolean                 @default(true)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  bookingLines BookingExtraServiceLine[]

  @@index([businessId, isActive])
}

model BookingExtraServiceLine {
  id                  String                  @id @default(uuid())
  bookingId           String
  eventId             String?
  extraServiceId      String
  quantity            Int                     @default(1)
  unitPriceSnapshot   Decimal                 @db.Decimal(12, 2)
  lineTotal           Decimal                 @db.Decimal(12, 2)
  titleSnapshot       String
  pricingTypeSnapshot ExtraServicePricingType
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  booking             Booking                 @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  event               BookingEvent?           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  extraService        ExtraService            @relation(fields: [extraServiceId], references: [id], onDelete: Restrict)

  @@index([bookingId])
  @@index([bookingId, eventId])
  @@index([extraServiceId])
}
