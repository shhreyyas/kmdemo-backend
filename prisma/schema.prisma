generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model LicenseCode {
  id               String   @id @default(uuid())
  code             String   @unique
  businessName     String
  prefix           String
  sequence         Int

  purchasePlan     Int      // months (1,3,6,12)
  subscriptionStart DateTime
  subscriptionEnd   DateTime
  isActive         Boolean  @default(true)

  isUsed           Boolean  @default(false)
  usedByUserId     String?
  usedAt           DateTime?

  createdAt        DateTime @default(now())
}

model Business {
  id                String   @id @default(uuid())
  name              String?
  ownerName         String?
  contactPerson     String?
  contactNumber     String?
  email             String?
  address           String?
  businessType      String[]
  yearsExperience   Int?
  registrationNumber String?
  gstNumber         String?
  logoUrl           String?

  isProfileCompleted Boolean @default(false)

  createdAt         DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now())


  users             User[]
}

model User {
  id           String   @id @default(uuid())
  businessId   String
  // Store the license info used by this user for quick reads.
  // (Business name is also stored redundantly for easy API response.)
  licenseCode String
  businessName String
  name         String
  email        String   @unique
  passwordHash String
  phoneNumber  String?
  role         String   @default("owner")
  isVerified   Boolean  @default(false)

  deletedAt    DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  business     Business @relation(fields: [businessId], references: [id])
  devices      UserDevice[]
}

model UserDevice {
  id         String   @id @default(uuid())
  userId     String
  deviceType Int
  fcmToken   String?
  createdAt  DateTime @default(now())

  user       User @relation(fields: [userId], references: [id])
}

model OtpCode {
  id        String   @id @default(uuid())
  email     String
  otp       String
  type      String
  expiresAt DateTime
  attempts  Int      @default(0)
  isUsed    Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}